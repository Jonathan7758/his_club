# History Content Pipeline — 环境变量配置
# 复制此文件为 .env 并填入实际值

# === 必填 ===
# DeepSeek LLM API
DEEPSEEK_API_KEY=sk-3ded85b7ccb4438fbe95ec7d45416e44
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bettafish
DB_USER=bettafish
DB_PASS=bettafish

# === 公众号对接 (从微信公众平台获取) ===
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here
WECHAT_TOKEN=your_server_token_here

# === 监控告警 (可选) ===
# Telegram Bot (推荐，免费)
# 1. 找 @BotFather 创建 bot 获取 token
# 2. 给 bot 发消息后访问 https://api.telegram.org/bot<TOKEN>/getUpdates 获取 chat_id
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234gh
# TELEGRAM_CHAT_ID=5956020377

# 钉钉机器人 Webhook
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx

# Sentry 错误追踪
# SENTRY_DSN=https://xxx@sentry.io/xxx

# 企业微信机器人 Webhook (可选)
# WECHAT_WORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# === 服务器标识 (可选) ===
SERVER_HOST=production
SENTRY_ENV=production
LOG_DIR=/opt/hisclub/logs
REPORT_DIR=/opt/hisclub/reports
